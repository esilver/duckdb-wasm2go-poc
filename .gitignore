# Regenerable large artifacts (see README.md for how to rebuild).
# build.sh -> duckdb_core.wasm ; transpile.sh -> duckdb_core_gen.go

# DuckDB amalgamation source + download (from the v1.5.3 release zip)
amalg/
libduckdb-src.zip

# Shallow upstream clone, used only to inspect scripts
/duckdb/

# The 85.8 MB standalone wasm (rebuild with ./build.sh)
duckdb_core.wasm

# The 490 MB wasm2go output (rebuild with ./transpile.sh)
duckdb_core_gen.go

# Compiled parsecheck binary (go build -o parsecheck ./parsecheck/main.go)
parsecheck/parsecheck

# macOS cruft
.DS_Store

# ---- Runnable PoC: regenerable large artifacts (rebuild via build_with_core.sh + rebuild_all.sh) ----
# All standalone wasm variants (-Oz, -O2, gc, core_functions, wasm-opt, ...)
*.wasm
duckdb_core.wasm.trackB
# wasm2go output (transpiled Go) + its embedded data
converge/genpkg/
converge_c/genpkg/
*_gen.go
*.dat
# Compiled driver binaries (~195 MB each)
converge/duckdb_run_*
converge_c/duckdb_run_*
# DuckDB v1.5.3 source clone (405 MB; git clone --depth 1 --branch v1.5.3 ...)
duckdb-src/
# Scratch second module dir used during build orchestration
converge_c/

# More regenerable artifacts (Tier2 host-FS + compiled demo/test binaries)
converge/fsgenpkg/
converge/duckdb_demo
converge/duckdb_run_*
converge/*.test
converge/fstest/fstest
converge/fstest/*.test
